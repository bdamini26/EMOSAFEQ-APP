rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: contacts
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - Owner UID
    //   - name: string (required, 1-50 chars)
    //   - phone: string (required, valid format)
    //   - isPrimary: bool (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: safe_zones
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable)
    //   - name: string (required, 1-50 chars)
    //   - address: string (required, 1-200 chars)
    //   - type: string (required, enum: home, work, college, other)
    //
    // Collection: emergency_logs
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable)
    //   - type: string (required, enum: MANUAL, SCREAM, TIMER_EXPIRED, BT_LOST)
    //   - location: map (optional, lat/lng numbers)
    //   - timestamp: timestamp (required)
    //   - audioCaptured: bool (optional)
    //   - aiAssessment: map (optional)
    //
    // Collection: settings
    // Document ID: userId
    // Fields:
    //   - unlockCode: string (required, 4 chars)
    //   - stealthMode: bool (optional)
    //   - autoSms: bool (optional)
    //   - updatedAt: timestamp (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidPhone(phone) {
      return phone is string && phone.matches("^\\+?[0-9\\s\\-\\(\\)]{7,20}$");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidContact(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             isValidPhone(data.phone) &&
             data.isPrimary is bool;
    }

    function isValidSafeZone(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.address is string && data.address.size() > 0 && data.address.size() <= 200 &&
             data.type in ['home', 'work', 'college', 'other'];
    }

    function isValidEmergencyLog(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.type in ['MANUAL', 'SCREAM', 'TIMER_EXPIRED', 'BT_LOST'] &&
             data.timestamp is timestamp;
    }

    function isValidSettings(data) {
      return data.unlockCode is string && data.unlockCode.size() == 4 &&
             (!('stealthMode' in data) || data.stealthMode is bool) &&
             (!('autoSms' in data) || data.autoSms is bool);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /contacts/{contactId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidContact(request.resource.data);
      allow update: if isDocOwner() && isValidContact(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /safe_zones/{zoneId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSafeZone(request.resource.data);
      allow update: if isDocOwner() && isValidSafeZone(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isDocOwner();
    }

    match /emergency_logs/{logId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidEmergencyLog(request.resource.data);
      // Logs are generally immutable for safety
      allow update, delete: if false;
    }

    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidSettings(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
